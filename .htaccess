DirectoryIndex public/index.php
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Prevent infinite rewrite loop when public/ is already targeted.
    RewriteRule ^public/ - [L]

    # Route app root directly to the front controller.
    RewriteRule ^$ public/index.php [L]

    # Don't rewrite if it's a real file.
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Rewrite everything else to /public.
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
